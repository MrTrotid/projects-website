---
import Layout from '../layouts/Layout.astro';
import TerminalPrompt from '../components/ui/TerminalPrompt.astro';
import TechStack from '../components/project/TechStack.astro';
import Screenshots from '../components/project/Screenshots.astro';
import ChallengeBox from '../components/project/ChallengeBox.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, repo, liveDemo, techStack, category, date, image, screenshots, challenges, lessons } = project.data;
const { Content } = await render(project);
---

<Layout title={title} description={description}>
  <section class="py-8 max-w-4xl mx-auto animate-fade-in-up">
    <!-- Back Navigation -->
    <a href="/" class="inline-flex items-center gap-2 text-terminal-green hover:text-terminal-greenDark transition-colors mb-8">
      <span>←</span>
      <span class="terminal-prompt">cd ../</span>
    </a>

    <!-- Project Header -->
    <div class="mb-8" transition:animate="slide">
      <div class="flex items-center gap-2 mb-4 text-sm text-terminal-text/60">
        <span class="text-terminal-green">#</span>
        <time datetime={date.toISOString()}>
          {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {category.map((cat) => (
          <span class="px-2 py-0.5 bg-terminal-green/10 text-terminal-green rounded text-xs">{cat}</span>
        ))}
      </div>

      <h1 class="text-3xl md:text-5xl font-bold mb-4 text-glow">{title}</h1>
      <p class="text-xl text-terminal-text/80 mb-6">{description}</p>

      <!-- Links -->
      <div class="flex flex-wrap gap-4 mb-6">
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-terminal-bgLight border border-terminal-green/30 rounded hover:bg-terminal-green/10 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <span class="terminal-prompt">view repo</span>
        </a>

        {liveDemo && (
          <a
            href={liveDemo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-terminal-green text-terminal-bg font-bold rounded hover:bg-terminal-greenDark transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            <span>live demo</span>
          </a>
        )}
      </div>

      <!-- Tech Stack -->
      <div class="mb-6">
        <p class="text-sm text-terminal-text/60 mb-2">$ cat tech_stack.txt</p>
        <TechStack techStack={techStack} />
      </div>
    </div>

    <!-- Project Image -->
    <div class="mb-8 rounded-lg overflow-hidden border border-terminal-green/20">
      <img src={image} alt={title} class="w-full h-auto" />
    </div>

    <!-- Screenshots -->
    <Screenshots screenshots={screenshots || []} title={title} />

    <!-- Challenges & Lessons -->
    {challenges.length > 0 && (
      <ChallengeBox title="Challenges Faced" items={challenges} type="challenges" />
    )}

    {lessons.length > 0 && (
      <ChallengeBox title="Lessons Learned" items={lessons} type="lessons" />
    )}

    <!-- Blog-style Writeup (MDX Content) -->
    <div class="mt-12 pt-8 border-t border-terminal-green/20">
      <h2 class="text-2xl font-bold mb-6 terminal-prompt">cat detailed_explanation.md</h2>
      <div class="markdown-content">
        <Content />
      </div>
    </div>
